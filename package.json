{
  "name": "@niiiiiiile/iw-jira-cli",
  "version": "0.5.0",
  "description": "CLI for Jira Cloud issue management with setup, profiles, and compact agent output",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    ".env.example"
  ],
  "bin": {
    "iw-jira-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "jira",
    "atlassian",
    "cli",
    "issue-tracker",
    "productivity"
  ],
  "author": "Teruaki Iwane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Niiiiile/jira-cli.git"
  },
  "homepage": "https://github.com/Niiiiile/jira-cli#readme",
  "bugs": {
    "url": "https://github.com/Niiiiile/jira-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "incur": "^0.3.25"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
